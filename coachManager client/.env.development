# Target Symfony from the Vite dev server (same-origin /api in the browser — avoids CORS).
# Matches compose.yaml backend port "8080:80". For Symfony CLI only, use http://localhost:8000
VITE_PROXY_TARGET=http://localhost:8080

# Do not set VITE_API_ORIGIN unless you really want cross-origin fetch from the browser (then CORS must be configured).
# If unset, the app calls /api on port 5173 and Vite proxies to VITE_PROXY_TARGET above.
