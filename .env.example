# Copy to `.env` next to compose.yaml. Docker Compose loads `.env` for variable substitution.

MYSQL_VERSION=8.4
MYSQL_DATABASE=coachManager_db
MYSQL_USER=coachManager_user
MYSQL_PASSWORD=coachManager_password
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
MYSQL_SERVER_VERSION=8.4

PHPMYADMIN_PORT=8081

APP_SECRET=change-this-secret-in-production
